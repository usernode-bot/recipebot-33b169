{
  "name": "RecipeBot",
  "icon": { "emoji": "🍳" },
  "llm": {
    "purpose": "Generates and refines cooking recipes in chat",
    "suggested_daily_cap_cents": 300
  },
  "secrets": [
    {
      "key": "BRAVE_SEARCH_API_KEY",
      "description": "Brave Search API key (api.search.brave.com) for the assistant's web_search tool. Optional — falls back to DuckDuckGo scraping when unset.",
      "required": false,
      "private": true
    },
    {
      "key": "ANTHROPIC_API_KEY",
      "description": "Optional direct Anthropic API key, used only when the platform LLM proxy is unavailable (staging/standalone). Leave unset to rely on the platform proxy.",
      "required": false,
      "private": true
    },
    {
      "key": "ANTHROPIC_MODEL",
      "description": "Default Claude model id for recipe chat (users can pick their own in App settings)",
      "required": false,
      "default": "claude-sonnet-5"
    },
    {
      "key": "THINKING_ENABLED",
      "description": "Enable extended thinking for recipe generation (true/false)",
      "required": false,
      "default": "true"
    },
    {
      "key": "THINKING_BUDGET",
      "description": "Max extended-thinking tokens per response",
      "required": false,
      "default": "4096"
    },
    {
      "key": "DEFAULT_DAILY_MSG_LIMIT",
      "description": "Daily chat message limit per user",
      "required": false,
      "default": "50"
    },
    {
      "key": "LOG_LEVEL",
      "description": "Server log level (DEBUG, INFO, WARN, ERROR)",
      "required": false,
      "default": "INFO"
    }
  ],
  "tests": [
    {
      "name": "App shell renders",
      "path": "/",
      "expectSelector": "#chat-panel"
    },
    {
      "name": "User menu button renders",
      "path": "/",
      "expectSelector": "#user-menu-btn"
    },
    {
      "name": "Settings modal exists",
      "path": "/",
      "expectSelector": "#settings-modal"
    },
    {
      "name": "User menu AI usage section exists",
      "path": "/",
      "expectSelector": "#usage-section"
    },
    {
      "name": "Homepage recipe search renders",
      "path": "/",
      "expectSelector": "#home-search"
    },
    {
      "name": "Homepage new recipe button renders",
      "path": "/",
      "expectSelector": "#new-conversation-btn"
    },
    {
      "name": "Homepage renders",
      "path": "/",
      "expectSelector": "#homepage"
    },
    {
      "name": "Homepage shows seeded shared recipe",
      "path": "/",
      "expectText": "Staging Demo Chicken Stir Fry"
    },
    {
      "name": "Homepage shows creator username",
      "path": "/",
      "expectText": "staging-demo-chef"
    },
    {
      "name": "Homepage shows Your recipes section",
      "path": "/",
      "expectText": "Your recipes"
    },
    {
      "name": "Header back button exists (hidden on home)",
      "path": "/",
      "expectSelector": "#home-btn"
    },
    {
      "name": "Three-state theme toggle renders",
      "path": "/",
      "expectSelector": "#icon-system"
    },
    {
      "name": "Update-note dialog exists",
      "path": "/",
      "expectSelector": "#share-note-modal"
    },
    {
      "name": "Version history modal exists",
      "path": "/",
      "expectSelector": "#version-history-modal"
    },
    {
      "name": "Community card shows seeded version badge",
      "path": "/",
      "expectText": "v2"
    }
  ]
}
